#!/bin/bash
# Installs fastfetch from the GitHub release .deb (not in Debian repos).
set -euo pipefail

RELEASE_URL="https://github.com/fastfetch-cli/fastfetch/releases/download/2.65.1/fastfetch-linux-amd64.deb"

curl -fsSL "$RELEASE_URL" -o /tmp/fastfetch.deb
dpkg -i /tmp/fastfetch.deb
rm /tmp/fastfetch.deb
