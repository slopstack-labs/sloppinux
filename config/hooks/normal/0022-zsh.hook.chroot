#!/bin/bash
# Installs Oh My Zsh system-wide and sets zsh as the default shell.
set -euo pipefail

echo "==> Installing Oh My Zsh"
git clone --depth=1 https://github.com/ohmyzsh/ohmyzsh.git /usr/share/oh-my-zsh

echo "==> Setting zsh as system default shell"
# New users created from this point will get zsh
sed -i 's|^SHELL=.*|SHELL=/bin/zsh|' /etc/default/useradd

# Set zsh for root and the pre-existing user skeleton
chsh -s /bin/zsh root
cp /etc/skel/.zshrc /root/.zshrc

echo "==> Done"
