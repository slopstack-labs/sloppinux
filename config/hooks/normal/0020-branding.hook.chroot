#!/bin/bash
set -euo pipefail
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# OS identity
cat > /etc/os-release <<'EOF'
PRETTY_NAME="Sloppinux 1.0 (Trixie 13.5)"
NAME="Sloppinux"
VERSION_ID="1.0"
VERSION="1.0 (Trixie 13.5)"
ID=sloppinux
ID_LIKE=debian
HOME_URL="https://github.com/slopstack-labs/sloppinux"
SUPPORT_URL="https://github.com/slopstack-labs/sloppinux/issues"
BUG_REPORT_URL="https://github.com/slopstack-labs/sloppinux/issues"
EOF

# Hostname
echo "sloppinux" > /etc/hostname
cat > /etc/hosts <<'EOF'
127.0.0.1   localhost
127.0.1.1   sloppinux
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters
EOF

# Wire LLM handler into bash.bashrc so it loads for ALL interactive shells,
# not just login shells (profile.d only runs for login shells)
cat >> /etc/bash.bashrc <<'EOF'

# Sloppinux: forward unknown commands to ollama
[ -f /etc/profile.d/sloppinux-llm.sh ] && . /etc/profile.d/sloppinux-llm.sh
EOF

# GNOME autologin for the live user
mkdir -p /etc/gdm3
cat > /etc/gdm3/custom.conf <<'EOF'
[daemon]
AutomaticLoginEnable=true
AutomaticLogin=user
EOF

# Replace the debian-logo.png that desktop-base ships — GDM points to this file
cp /usr/share/pixmaps/sloppinux-logo.png /usr/share/pixmaps/debian-logo.png

# Compile dconf database so GDM picks up the logo
dconf update

# Plymouth boot splash — set via both mechanisms for reliability
mkdir -p /etc/plymouth
cat > /etc/plymouth/plymouthd.conf <<'EOF'
[Daemon]
Theme=sloppinux
ShowDelay=0
EOF
plymouth-set-default-theme -R sloppinux

echo "Sloppinux 1.0 (Trixie 13.5) — inference-first Linux" > /etc/issue
echo "Sloppinux 1.0 (Trixie 13.5) — inference-first Linux" > /etc/issue.net
